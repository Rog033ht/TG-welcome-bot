BOT_TOKEN=123456:replace_me
DB_URL=sqlite+aiosqlite:///./data/bot.sqlite3
LOG_LEVEL=INFO

# Links (PH high-conversion menu)
GROUPS_URL=https://t.me/your_group_or_channel
APP_URL=https://example.com/download
OFFICIAL_BOT_URL=https://t.me/your_official_bot
SUPPORT_URL=https://t.me/your_support
COMMENT_URL=https://t.me/your_comment_group
CONVERSION_URL=https://example.com/convert

# Broadcast anti-spam uniqueness
BROADCAST_UNIQUE_SUFFIX=true

# Admins (comma-separated Telegram user IDs)
ADMIN_IDS=

# Broadcast rate limit (messages per second, safe <= 30)
BROADCAST_RPS=30

# Gemini Flash AI localization
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
